{
  "printWidth": 100,
  "singleQuote": true,
  "semi": false,
  "trailingComma": "es5",
  "tabWidth": 2,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "plugins": [
    "@ianvs/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss",
    "prettier-plugin-prisma"
  ],
  "importOrder": [
    "^(server|client)-only$",
    "<BUILTIN_MODULES>",
    "<THIRD_PARTY_MODULES>",
    "",
    "^@/(.*)$",
    "^\\./(?!.*\\.(css|scss|less)$).*$",
    "^\\.\\./(?!.*\\.(css|scss|less)$).*$",
    "\\.(css|scss|less)$"
  ]
}
